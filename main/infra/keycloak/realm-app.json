{
  "realm": "app",
  "enabled": true,
  "registrationAllowed": false,
  "resetPasswordAllowed": false,
  "rememberMe": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": true,
  "roles": {
    "realm": [
      { "name": "secretary" },
      { "name": "teacher" },
      { "name": "expert" },
      { "name": "external_expert" }
    ]
  },
  "clients": [
    {
      "clientId": "frontend",
      "name": "frontend",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["http://localhost:3000/*", "https://scarmoon.it123.ru/*"],
      "webOrigins": ["http://localhost:3000", "https://scarmoon.it123.ru"],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:3000/*,https://scarmoon.it123.ru/*",
        "pkce.code.challenge.method": "S256",
        "pkce.supported": "true"
      }
    }
  ],
  "users": [
    {
      "username": "secretary",
      "enabled": true,
      "firstName": "Секретарь",
      "lastName": "Системы",
      "email": "secretary@example.local",
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "1234", "temporary": false }],
      "realmRoles": ["secretary"]
    }
  ]
}

