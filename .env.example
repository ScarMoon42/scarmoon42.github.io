# База данных (PostgreSQL 17+)
DATABASE_URL="postgresql://postgres:password@127.0.0.1:5432/myapp?schema=public"

# Redis 7+ (опционально, для сессий и кэша)
REDIS_URL="redis://127.0.0.1:6379"

# API
PORT=3001
CORS_ORIGIN=

# Frontend (Vite)
VITE_API_URL=http://127.0.0.1:3001
VITE_BASE_PATH=/

# Keycloak Configuration
KEYCLOAK_URL=http://127.0.0.1:8080
KEYCLOAK_REALM=app
KEYCLOAK_CLIENT_ID=frontend
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Frontend Keycloak (build-time fallbacks)
VITE_KEYCLOAK_URL=http://127.0.0.1:8080
VITE_KEYCLOAK_REALM=app
VITE_KEYCLOAK_CLIENT_ID=frontend

# Frontend Keycloak (runtime for Docker/Domain deployment)
# Set this to your external domain where Keycloak is accessible (e.g. https://auth.my-domain.com)
KEYCLOAK_FRONTEND_URL=http://127.0.0.1:8080

# Docker Compose Exposed Ports (Host)
# Порты, которые будут "смотреть" наружу при запуске через docker-compose
APP_PORT=3000
KEYCLOAK_PORT=8080
GRAFANA_PORT=3002
