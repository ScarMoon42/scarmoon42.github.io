# База данных (PostgreSQL 17+)
DATABASE_URL="postgresql://postgres:password@127.0.0.1:5432/myapp?schema=public"

# Redis 7+ (опционально, для сессий и кэша)
REDIS_URL="redis://127.0.0.1:6379"

# API
PORT=3001
CORS_ORIGIN=

# Frontend (Vite)
VITE_API_URL=http://127.0.0.1:3001
VITE_BASE_PATH=/

# Keycloak Configuration
# Можно задать полным URL (например, https://auth.domain.com/auth или http://127.0.0.1:8080/auth)
KEYCLOAK_URL=http://127.0.0.1:8080/auth
# Или собрать URL из частей (используется, если KEYCLOAK_URL пустой)
KEYCLOAK_SCHEME=http
KEYCLOAK_HOST=127.0.0.1
KEYCLOAK_PORT=8080
KEYCLOAK_BASE_PATH=
KEYCLOAK_REALM=app
KEYCLOAK_CLIENT_ID=frontend
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
# Включить только при self-signed сертификате на внешнем Keycloak (не для production)
KEYCLOAK_TLS_INSECURE=false

# Frontend Keycloak (build-time fallbacks)
VITE_KEYCLOAK_URL=http://127.0.0.1:8080/auth
VITE_KEYCLOAK_REALM=app
VITE_KEYCLOAK_CLIENT_ID=frontend
# Использовать silent-check-sso через iframe (может блокироваться CSP на Keycloak)
VITE_KEYCLOAK_SILENT_CHECK_SSO=false

# Frontend Keycloak (runtime for Docker/Domain deployment)
# Set this to your external domain where Keycloak is accessible (e.g. https://auth.my-domain.com)
KEYCLOAK_FRONTEND_URL=http://127.0.0.1:8080/auth
# Или собрать внешний URL из частей (используется, если KEYCLOAK_FRONTEND_URL пустой)
KEYCLOAK_FRONTEND_SCHEME=http
KEYCLOAK_FRONTEND_HOST=127.0.0.1
KEYCLOAK_FRONTEND_PORT=8080
KEYCLOAK_FRONTEND_BASE_PATH=
# Дополнительные issuer-базы через запятую (если токены приходят с альтернативных host/port)
# Пример: KEYCLOAK_ISSUER_ALIASES=https://auth.local,https://kc.internal:8443
KEYCLOAK_ISSUER_ALIASES=

# Docker Compose Exposed Ports (Host)
# Порты, которые будут "смотреть" наружу при запуске через docker-compose
APP_PORT=3000
KEYCLOAK_PORT=8080
GRAFANA_PORT=3002
